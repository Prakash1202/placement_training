10. Geek-onacci Number

public class Geekonacci {
    public static int geekonacci(int a, int b, int c, int n) {
        if (n == 1) return a;
        if (n == 2) return b;
        if (n == 3) return c;
        return geekonacci(a, b, c, n - 1) + geekonacci(a, b, c, n - 2) + geekonacci(a, b, c, n - 3);
    }

    public static void main(String[] args) {
        System.out.println(geekonacci(1, 3, 2, 4));
    }
}
Output:
6


11. Recursive Bubble SortJavaimport java.util.Arrays;

public class RecursiveBubbleSort {
    public static void bubbleSort(int[] arr, int n) {
        if (n == 1) return;

        for (int i = 0; i < n - 1; i++) {
            if (arr[i] > arr[i + 1]) {
                int temp = arr[i];
                arr[i] = arr[i + 1];
                arr[i + 1] = temp;
            }
        }

        bubbleSort(arr, n - 1);
    }

    public static void main(String[] args) {
        int[] arr = {64, 34, 25, 12, 22, 11, 90};
        bubbleSort(arr, arr.length);
        System.out.println(Arrays.toString(arr));
    }
}
Output:
[11, 12, 22, 25, 34, 64, 90]


12. Recursive Insertion SortJavaimport java.util.Arrays;

public class RecursiveInsertionSort {
    public static void insertionSort(int[] arr, int n) {
        if (n <= 1) return;

        insertionSort(arr, n - 1);

        int last = arr[n - 1];
        int j = n - 2;

        while (j >= 0 && arr[j] > last) {
            arr[j + 1] = arr[j];
            j--;
        }
        arr[j + 1] = last;
    }

    public static void main(String[] args) {
        int[] arr = {12, 11, 13, 5, 6};
        insertionSort(arr, arr.length);
        System.out.println(Arrays.toString(arr));
    }
}
Output:
[5, 6, 11, 12, 13]


13. Sum of Digit of a Number using Recursion

public class SumOfDigits {
    public static int sumDigits(int n) {
        if (n == 0) return 0;
        return (n % 10) + sumDigits(n / 10);
    }

    public static void main(String[] args) {
        System.out.println(sumDigits(12345));
    }
}
Output:
15


14. Product of Two Numbers using Recursion

public class ProductRecursion {
    public static int product(int x, int y) {
        if (x < y) return product(y, x);
        if (y != 0) return x + product(x, y - 1);
        return 0;
    }

    public static void main(String[] args) {
        System.out.println(product(5, 2));
    }
}
Output:
10
