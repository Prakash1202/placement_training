7. Fibonacci Number

public class Fibonacci {
    public static int fib(int n) {
        if (n <= 1) return n;
        return fib(n - 1) + fib(n - 2);
    }

    public static void main(String[] args) {
        System.out.println(fib(4));
    }
}
Output:
3


8. Special Fibonacci

public class SpecialFibonacci {
    public static int specialFib(int a, int b, int n) {
        if (n % 3 == 0) return a;
        if (n % 3 == 1) return b;
        return a ^ b;
    }

    public static void main(String[] args) {
        System.out.println(specialFib(86, 77, 15));
    }
}
Output:
86


9. Length of String using Recursion

public class StringLength {
    public static int recLength(String str) {
        if (str.equals("")) return 0;
        return 1 + recLength(str.substring(1));
    }

