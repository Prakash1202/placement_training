13. Jump Game VII

import java.util.LinkedList;
import java.util.Queue;

public class JumpGameVII {
    public static boolean canReach(String s, int minJump, int maxJump) {
        if (s.charAt(s.length() - 1) != '0') return false;

        Queue<Integer> queue = new LinkedList<>();
        queue.offer(0);
        int farthest = 0;

        while (!queue.isEmpty()) {
            int idx = queue.poll();
            int start = Math.max(idx + minJump, farthest + 1);
            int end = Math.min(idx + maxJump, s.length() - 1);

            for (int j = start; j <= end; j++) {
                if (s.charAt(j) == '0') {
                    if (j == s.length() - 1) return true;
                    queue.offer(j);
                }
            }
            farthest = Math.max(farthest, idx + maxJump);
        }

        return false;
    }

    public static void main(String[] args) {
        String s = "00110010";
        System.out.println(canReach(s, 2, 4));
    }
}
Output
true


14. Split Two Strings to Make Palindrome

public class SplitTwoStrings {
    public static boolean checkPalindromeFormation(String a, String b) {
        return check(a, b) || check(b, a);
    }

    private static boolean check(String a, String b) {
        int left = 0, right = a.length() - 1;
        while (left < right && a.charAt(left) == b.charAt(right)) {
            left++;
            right--;
        }
        return isPalindrome(a, left, right) || isPalindrome(b, left, right);
    }

    private static boolean isPalindrome(String s, int left, int right) {
        while (left < right) {
            if (s.charAt(left) != s.charAt(right)) return false;
            left++;
            right--;
        }
        return true;
    }

    public static void main(String[] args) {
        String a = "xabcba", b = "abcba";
        System.out.println(checkPalindromeFormation("x", "y"));
    }
}
Output:
true


15. Number of Ways to Split a String

import java.util.ArrayList;
import java.util.List;

public class NumberOfWaysToSplit {
    public static int numWays(String s) {
        int MOD = 1000000007;
        List<Integer> onesIndices = new ArrayList<>();
        int n = s.length();

        for (int i = 0; i < n; i++) {
            if (s.charAt(i) == '1') {
                onesIndices.add(i);
            }
        }

        int countOnes = onesIndices.size();

        if (countOnes == 0) {
            long ways = (long) (n - 1) * (n - 2) / 2;
            return (int) (ways % MOD);
        }

        if (countOnes % 3 != 0) {
            return 0;
        }

        int k = countOnes / 3;
        long waysFirstSplit = onesIndices.get(k) - onesIndices.get(k - 1);
        long waysSecondSplit = onesIndices.get(2 * k) - onesIndices.get(2 * k - 1);

        return (int) ((waysFirstSplit * waysSecondSplit) % MOD);
    }

    public static void main(String[] args) {
        String s = "10101";
        System.out.println(numWays(s));
    }
}
Output:
4


16. Sentence Similarity III

public class SentenceSimilarityIII {
    public static boolean areSentencesSimilar(String sentence1, String sentence2) {
        String[] words1 = sentence1.split(" ");
        String[] words2 = sentence2.split(" ");

        int i = 0, j1 = words1.length - 1, j2 = words2.length - 1;

        while (i < words1.length && i < words2.length && words1[i].equals(words2[i])) {
            i++;
        }

        while (j1 >= i && j2 >= i && words1[j1].equals(words2[j2])) {
            j1--;
            j2--;
        }

        return j1 < i || j2 < i;
    }

    public static void main(String[] args) {
        String sentence1 = "My name is Haley", sentence2 = "My Haley";
        System.out.println(areSentencesSimilar(sentence1, sentence2));
    }
}
Output
true


