4. Area Of Isosceles Triangle

import java.util.Scanner;

public class AreaOfIsoscelesTriangle {
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        System.out.print("Enter length of equal sides (a): ");
        double a = scanner.nextDouble();
        System.out.print("Enter base (b): ");
        double b = scanner.nextDouble();

        // Area formula: (b / 4) * sqrt(4*a^2 - b^2)
        double area = (b / 4.0) * Math.sqrt((4 * a * a) - (b * b));
        System.out.printf("Area of Isosceles Triangle: %.2f\n", area);

        scanner.close();
    }
}
Output

Enter length of equal sides (a): 5
Enter base (b): 6
Area of Isosceles Triangle: 12.00


