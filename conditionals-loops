9. Calculate Batting AverageQuestionWrite a Java program to calculate a cricket batter's average using the formula:$$\text{Batting Average} = \frac{\text{Total Runs}}{\text{Total Innings} - \text{Not Out Count}}$$CodeJavaimport java.util.Scanner;

public class BattingAverage {
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        System.out.print("Enter total runs scored: ");
        int runs = scanner.nextInt();
        System.out.print("Enter total innings played: ");
        int innings = scanner.nextInt();
        System.out.print("Enter number of times remaining Not Out: ");
        int notOuts = scanner.nextInt();

        int dismissals = innings - notOuts;

        if (dismissals <= 0) {
            System.out.println("Batting Average cannot be calculated (0 dismissals).");
        } else {
            double battingAvg = (double) runs / dismissals;
            System.out.printf("Batting Average: %.2f\n", battingAvg);
        }

        scanner.close();
    }
}
Output:
Enter total runs scored: 1250
Enter total innings played: 30
Enter number of times remaining Not Out: 5
Batting Average: 50.00


10. Calculate CGPA Java ProgramQuestionWrite a Java program to compute Cumulative Grade Point Average (CGPA) given the grade points obtained in $N$ subjects.CodeJavaimport java.util.Scanner;

public class CalculateCGPA {
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        System.out.print("Enter total number of subjects: ");
        int subjects = scanner.nextInt();

        double totalGradePoints = 0;
        for (int i = 1; i <= subjects; i++) {
            System.out.print("Enter grade point obtained in subject " + i + " (out of 10): ");
            totalGradePoints += scanner.nextDouble();
        }

        double cgpa = (subjects > 0) ? (totalGradePoints / subjects) : 0;
        double percentage = cgpa * 9.5; // Standard CBSE conversion multiplier

        System.out.printf("Overall CGPA: %.2f\n", cgpa);
        System.out.printf("Equivalent Percentage: %.2f%%\n", percentage);

        scanner.close();
    }
}

